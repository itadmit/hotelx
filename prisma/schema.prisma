generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(cuid())
  name             String?
  email            String         @unique
  password         String?
  emailVerified    DateTime?
  image            String?
  role             Role           @default(STAFF)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  lastLoginAt      DateTime?
  hotelId          String?
  assignedRequests Request[]
  notifications    Notification[]
  hotel            Hotel?         @relation(fields: [hotelId], references: [id])
}

model Hotel {
  id              String            @id @default(cuid())
  name            String
  slug            String            @unique
  logo            String?
  primaryColor    String?           @default("#2563eb")
  paymentsEnabled Boolean           @default(false)
  defaultCurrency String            @default("USD")
  feedbackEnabled    Boolean        @default(true)
  feedbackThreshold  Int            @default(4)
  googleReviewUrl    String?
  bookingReviewUrl   String?
  supportEmail       String?
  demoSeedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  categories      Category[]
  requests        Request[]
  rooms           Room[]
  services        Service[]
  users           User[]
  paymentProviders PaymentProvider[]
  payments        Payment[]
  notifications   Notification[]
  info            HotelInfo?
  amenities       HotelAmenity[]
  feedbacks       Feedback[]
  emailTemplates  HotelEmailTemplate[]
  emailLogs       EmailLog[]
}

model HotelInfo {
  hotelId      String   @id
  wifiName     String?
  wifiPassword String?
  wifiNotes    String?
  about        String?
  helpfulInfo  String?
  updatedAt    DateTime @updatedAt
  hotel        Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
}

model HotelAmenity {
  id          String   @id @default(cuid())
  hotelId     String
  name        String
  description String?
  icon        String?
  hours       String?
  location    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  hotel       Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, order])
}

model Room {
  id            String         @id @default(cuid())
  number        String
  code          String         @unique
  type          String?
  status        RoomStatus     @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  hotelId       String
  requests      Request[]
  notifications Notification[]
  hotel         Hotel          @relation(fields: [hotelId], references: [id])

  @@unique([hotelId, number])
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String
  icon      String?
  order     Int        @default(0)
  hotelId   String
  parentId  String?
  hotel     Hotel      @relation(fields: [hotelId], references: [id])
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Category[] @relation("CategoryTree")
  services  Service[]

  @@unique([hotelId, slug])
  @@index([hotelId, parentId])
}

model Service {
  id             String    @id @default(cuid())
  name           String
  description    String?
  price          Decimal?  @db.Decimal(10, 2)
  currency       String    @default("USD")
  estimatedTime  String?
  image          String?
  isActive       Boolean   @default(true)
  isFeatured     Boolean   @default(false)
  requirePayment Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  hotelId        String
  categoryId     String
  requests       Request[]
  payments       Payment[]
  category       Category  @relation(fields: [categoryId], references: [id])
  hotel          Hotel     @relation(fields: [hotelId], references: [id])

  @@index([hotelId, isFeatured])
}

model Request {
  id          String        @id @default(cuid())
  status      RequestStatus @default(NEW)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  completedAt DateTime?
  hotelId     String
  roomId      String
  serviceId   String
  assigneeId  String?
  paymentId   String?       @unique
  assignee      User?          @relation(fields: [assigneeId], references: [id])
  hotel         Hotel          @relation(fields: [hotelId], references: [id])
  room          Room           @relation(fields: [roomId], references: [id])
  service       Service        @relation(fields: [serviceId], references: [id])
  payment       Payment?       @relation(fields: [paymentId], references: [id])
  notifications Notification[]
  feedback      Feedback?
}

model PaymentProvider {
  id           String              @id @default(cuid())
  hotelId      String
  type         PaymentProviderType
  displayName  String
  isActive     Boolean             @default(true)
  isDefault    Boolean             @default(false)
  publicConfig Json                @default("{}")
  secretConfig String              @default("")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  hotel        Hotel               @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  payments     Payment[]

  @@index([hotelId])
}

model Payment {
  id            String              @id @default(cuid())
  hotelId       String
  serviceId     String
  roomId        String
  providerId    String?
  providerType  PaymentProviderType
  externalId    String?
  amount        Decimal             @db.Decimal(10, 2)
  currency      String              @default("USD")
  status        PaymentStatus       @default(PENDING)
  errorMessage  String?
  metadata      Json                @default("{}")
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  paidAt        DateTime?
  hotel         Hotel               @relation(fields: [hotelId], references: [id])
  service       Service             @relation(fields: [serviceId], references: [id])
  provider      PaymentProvider?    @relation(fields: [providerId], references: [id])
  request       Request?

  @@index([hotelId])
  @@index([providerId])
  @@index([externalId])
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum RoomStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

enum RequestStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentProviderType {
  STRIPE
  PAYPAL
  CUSTOM
  MOCK
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

model Notification {
  id        String               @id @default(cuid())
  hotelId   String
  audience  NotificationAudience
  type      NotificationType
  title     String
  body      String?
  href      String?
  metadata  Json                 @default("{}")
  roomId    String?
  requestId String?
  userId    String?
  readAt    DateTime?
  createdAt DateTime             @default(now())
  hotel     Hotel                @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  room      Room?                @relation(fields: [roomId], references: [id])
  request   Request?             @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user      User?                @relation(fields: [userId], references: [id])

  @@index([hotelId, audience, readAt, createdAt])
  @@index([roomId, readAt, createdAt])
}

enum NotificationAudience {
  STAFF
  GUEST
}

enum NotificationType {
  REQUEST_CREATED
  REQUEST_STATUS_CHANGED
  REQUEST_ASSIGNED
  REQUEST_COMPLETED
  PAYMENT_PAID
  PAYMENT_FAILED
  FEEDBACK_RECEIVED
  FEEDBACK_ESCALATION
}

model Feedback {
  id           String           @id @default(cuid())
  hotelId      String
  requestId    String           @unique
  rating       Int
  comment      String?
  guestName    String?
  guestEmail   String?
  sentiment    FeedbackSentiment
  status       FeedbackStatus   @default(NEW)
  resolvedAt   DateTime?
  resolvedById String?
  resolutionNote String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  hotel        Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  request      Request          @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([hotelId, sentiment, status, createdAt])
}

enum FeedbackSentiment {
  POSITIVE
  NEGATIVE
}

enum FeedbackStatus {
  NEW
  IN_REVIEW
  RESOLVED
}

model HotelEmailTemplate {
  id        String           @id @default(cuid())
  hotelId   String?
  kind      EmailTemplateKind
  subject   String
  heading   String
  body      String
  ctaLabel  String?
  ctaUrl    String?
  isActive  Boolean          @default(true)
  updatedAt DateTime         @updatedAt
  createdAt DateTime         @default(now())
  hotel     Hotel?           @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, kind])
}

enum EmailTemplateKind {
  FEEDBACK_THANKS
  FEEDBACK_APOLOGY
  PASSWORD_RESET
  TEAM_INVITE
  WELCOME
}

model EmailLog {
  id          String       @id @default(cuid())
  hotelId     String?
  to          String
  subject     String
  template    EmailTemplateKind?
  provider    String       @default("resend")
  externalId  String?
  status      EmailStatus  @default(SENT)
  error       String?
  meta        Json         @default("{}")
  createdAt   DateTime     @default(now())
  hotel       Hotel?       @relation(fields: [hotelId], references: [id], onDelete: SetNull)

  @@index([hotelId, createdAt])
  @@index([to, createdAt])
}

enum EmailStatus {
  SENT
  FAILED
  SIMULATED
}
